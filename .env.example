# Copy to .env and fill in real values — never commit .env

# Shared
DATABASE_URL=postgresql://user:password@localhost:5432/perf_marketing

# Pipelines (Python)
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

# Slack (Native Ads pipeline)
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_CHANNEL_ID=C09FCDHFGCU

# GetKlar (Daily Spend Report pipeline)
# GETKLAR_API_TOKEN is for the data-import API (open-api.getklar.com) — used elsewhere.
# GETKLAR_REFRESH_TOKEN is the SEPARATE token for the Attribution API.
# Obtain it from: Klar Frontend → Store Settings → Attribution API
GETKLAR_REFRESH_TOKEN=
GETKLAR_TEMPLATE_URL=
# MS Teams incoming webhook URL for the daily spend report.
# If unset, the report is printed to stdout only.
TEAMS_WEBHOOK_URL=

# Dashboard (Next.js)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
